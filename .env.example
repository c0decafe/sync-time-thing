SYNCTIMETHING_ADMIN_USERNAME=admin
SYNCTIMETHING_ADMIN_PASSWORD=change-me
SYNCTIMETHING_LISTEN_ADDR=:8080
SYNCTIMETHING_DATA_DIR=./data
SYNCTIMETHING_TIMEZONE=UTC
SYNCTIMETHING_SESSION_TTL=24h
SYNCTIMETHING_SECURE_COOKIES=false
# base64-encoded 32-byte key used to encrypt stored Syncthing API credentials
SYNCTIMETHING_ENCRYPTION_KEY=
SYNCTIMETHING_RULE_RUN_RETENTION=2160h
